---
/**
 * PostLayout — calmer reading shell for individual posts.
 *
 * Renders the Layout chrome (Header / Footer / SEO) and a narrow-measure
 * article body with a title + author byline (avatar · name in bold,
 * role underneath). Strips AstroPaper's default breadcrumb, share
 * links, edit-post link, table of contents, related posts, prev/next
 * nav, category, and tags — the design calls for a quiet single-column
 * page.
 *
 * Prose styles live in `src/styles/global.css` under `.post-prose` so
 * markdown-rendered descendants pick them up.
 */
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Layout from "./Layout.astro";
import config from "@/config";

type Props = {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  /** Approximate read time in minutes — omitted if undefined. */
  readingMinutes?: number;
  /** Author byline — resolved from the post's team-collection
   *  reference by the slug page and passed in. */
  authorName: string;
  authorRole: string;
  authorPhoto: ImageMetadata;
  currentPage?: "landing" | "post" | "archives" | "tags" | "search";
};

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  readingMinutes,
  authorName,
  authorRole,
  authorPhoto,
  currentPage,
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: ogImage,
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [{ "@type": "Person", name: authorName }],
};

const monthYear = pubDatetime
  ? new Intl.DateTimeFormat("en-GB", {
      year: "numeric",
      month: "long",
    }).format(pubDatetime)
  : undefined;

// Meta-strip segments — drop anything that is missing rather than
// rendering empty slots.
const metaParts = [
  monthYear,
  readingMinutes ? `${readingMinutes} min read` : undefined,
].filter((part): part is string => Boolean(part));
---

<Layout
  title={`${title} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  currentPage={currentPage ?? "post"}
>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
  </Fragment>

  <article class="post" data-pagefind-body>
    <header class="post-head">
      {
        metaParts.length > 0 && (
          <div class="post-meta">
            {metaParts.map((part, i) => (
              <Fragment>
                {i > 0 && (
                  <span class="mono-sep" aria-hidden="true">
                    ·
                  </span>
                )}
                <span class="mono-seg">{part}</span>
              </Fragment>
            ))}
          </div>
        )
      }
      <h1 class="post-title">{title}</h1>
      <div class="post-byline">
        <Image
          class="byline-photo"
          src={authorPhoto}
          alt={authorName}
          widths={[80, 120, 160]}
          sizes="56px"
        />
        <div class="byline-text">
          <span class="byline-name">{authorName}</span>
          <span class="byline-role">{authorRole}</span>
        </div>
      </div>
    </header>

    <div class="post-prose">
      <slot />
    </div>

    <footer class="post-foot">
      <a class="back-link mono" href="/posts">← back to all notes</a>
    </footer>
  </article>
</Layout>

<style>
  /* Page-scoped wrappers. Prose styles for markdown-rendered descendants
     live in global.css so they cascade past Astro's scope-hash. */
  .post {
    max-width: 68ch;
    margin: 0 auto;
    padding: 80px 40px 96px;
  }

  .post-head {
    margin-bottom: 48px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brand-mid);
    flex-wrap: wrap;
  }

  .post-meta .mono-sep {
    color: var(--border-strong);
  }

  .post-title {
    font-family: var(--font-head);
    font-size: 44px;
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 500;
    font-variation-settings:
      "SOFT" 50,
      "WONK" 0,
      "opsz" 96;
    margin: 0;
  }

  @media (max-width: 620px) {
    .post {
      padding: 56px 24px 72px;
    }
    .post-title {
      font-size: 34px;
    }
  }

  /* Title → byline (avatar + name + role). */
  .post-byline {
    margin-top: 22px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .post-byline :global(.byline-photo) {
    display: block;
    width: 56px;
    height: 56px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 50%;
    background: var(--secondary);
    flex-shrink: 0;
  }
  .byline-text {
    display: flex;
    flex-direction: column;
    line-height: 1.35;
  }
  .byline-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--fg);
  }
  .byline-role {
    font-size: 13px;
    color: var(--muted);
  }

  .post-foot {
    max-width: 68ch;
    margin: 64px auto 0;
    padding-top: 24px;
    border-top: 1px dashed var(--border);
  }

  .back-link {
    color: var(--brand-mid);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back-link:hover {
    color: var(--fg);
  }
</style>
