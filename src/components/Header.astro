---
/**
 * Floating header — wordmark hard-left, nav hard-right, no background,
 * no sticky bar. Absolutely positioned at the top so the page content
 * (hero gradient) reaches the very edge and scrolls underneath.
 *
 * Anchor rewriting:
 *   - On the landing page (currentPage === "landing"), nav hrefs stay as
 *     in-page fragments ("#problem", "#approach", …) and the logo points
 *     to "#top".
 *   - On any other page (undefined or any other value), hrefs are
 *     prefixed with "/" so they navigate back to the landing page and
 *     scroll to the target — e.g. "#problem" → "/#problem".
 */
import { getSite } from "@/utils/getSite";

type Props = {
  currentPage?: "landing" | "post" | "archives" | "tags" | "search";
};

const { currentPage } = Astro.props;
const isLanding = currentPage === "landing";

const site = await getSite();

/** "#foo" → "/#foo" on non-landing pages. */
const rewriteHash = (href: string): string => {
  if (isLanding) return href;
  if (href.startsWith("#")) return `/${href}`;
  return href;
};

const logoHref = isLanding ? "#top" : "/";
---

<header class="rg-header">
  <div class="rg-header-inner">
    <a class="rg-logo" href={logoHref}>
      <span class="mark" aria-hidden="true"></span>
      <span class="name">ReliaParse</span>
    </a>
    <nav class="rg-nav" aria-label="Primary">
      {
        site.nav.map(link => (
          <a href={rewriteHash(link.href)}>{link.label}</a>
        ))
      }
      <a
        href={rewriteHash(site.header_cta.href)}
        class="btn-primary rg-header-cta"
      >
        {site.header_cta.label}
      </a>
    </nav>
  </div>
</header>

<style>
  /* Absolute, transparent header — scrolls away with the page and lets
     the hero gradient run edge-to-edge underneath. */
  .rg-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 5;
    background: transparent;
  }
  .rg-header-inner {
    max-width: none;
    margin: 0;
    height: 84px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
  }
  .rg-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
  }
  .rg-logo .mark {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--gradient-accent);
  }
  .rg-logo .name {
    font-family: var(--font-head);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 30px;
    color: var(--fg);
  }
  .rg-nav {
    display: flex;
    align-items: center;
    gap: 30px;
    font-size: 15px;
  }
  .rg-nav a {
    color: var(--fg);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.15s;
  }
  .rg-nav a:hover {
    color: var(--brand-mid);
  }

  .rg-header-cta {
    padding: 9px 16px;
    font-size: 13px;
    white-space: nowrap;
  }
  .rg-nav a.rg-header-cta,
  .rg-nav a.rg-header-cta:hover {
    color: var(--primary-fg);
  }

  /* Collapse nav at narrow widths; CTA stays so the primary action
     remains within reach. */
  @media (max-width: 900px) {
    .rg-nav {
      gap: 18px;
    }
  }
  @media (max-width: 720px) {
    .rg-header-inner {
      padding: 0 20px;
    }
    .rg-nav > a:not(.rg-header-cta) {
      display: none;
    }
  }
</style>
