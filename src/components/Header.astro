---
/**
 * Sticky header — logo, in-page nav, and a "Pilot with us" CTA.
 *
 * Anchor rewriting:
 *   - On the landing page (currentPage === "landing"), nav hrefs stay as
 *     in-page fragments ("#problem", "#approach", …) and the logo points
 *     to "#top".
 *   - On any other page (undefined or any other value), hrefs are
 *     prefixed with "/" so they navigate back to the landing page and
 *     scroll to the target — e.g. "#problem" → "/#problem".
 */
import { getSite } from "@/utils/getSite";

type Props = {
  currentPage?: "landing" | "post" | "archives" | "tags" | "search";
};

const { currentPage } = Astro.props;
const isLanding = currentPage === "landing";

const site = await getSite();

/** "#foo" → "/#foo" on non-landing pages. */
const rewriteHash = (href: string): string => {
  if (isLanding) return href;
  if (href.startsWith("#")) return `/${href}`;
  return href;
};

const logoHref = isLanding ? "#top" : "/";
---

<header class="rg-header">
  <div class="rg-header-inner">
    <a class="rg-logo" href={logoHref}>
      <span class="mark" aria-hidden="true"></span>
      <span class="name">ReliaGround</span>
      <span class="aff">{site.affiliation}</span>
    </a>
    <nav class="rg-nav" aria-label="Primary">
      {
        site.nav.map(link => (
          <a href={rewriteHash(link.href)}>{link.label}</a>
        ))
      }
      <a
        href={rewriteHash(site.header_cta.href)}
        class="btn-primary rg-header-cta"
      >
        {site.header_cta.label}
      </a>
    </nav>
  </div>
</header>

<style>
  /* ── HEADER ────────────────────────────────────────────────────
     Ported from template.html lines 99–124. */
  .rg-header {
    position: sticky;
    top: 0;
    z-index: 5;
    background: color-mix(in oklch, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .rg-header-inner {
    max-width: 1180px;
    margin: 0 auto;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
  }
  .rg-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }
  .rg-logo .mark {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: var(--gradient-accent);
  }
  .rg-logo .name {
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 15px;
  }
  .rg-logo .aff {
    font-size: 12px;
    color: var(--muted);
    border-left: 1px solid var(--border);
    padding-left: 10px;
    margin-left: 4px;
  }
  .rg-nav {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 14px;
  }
  .rg-nav a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .rg-nav a:hover {
    color: var(--fg);
  }

  /* Smaller pill for the header version of .btn-primary —
     matches the inline overrides in template.html line 522. */
  .rg-header-cta {
    padding: 7px 14px;
    font-size: 13px;
  }
  .rg-nav a.rg-header-cta {
    color: var(--primary-fg);
  }
  .rg-nav a.rg-header-cta:hover {
    color: var(--primary-fg);
  }

  /* ── RESPONSIVE ───────────────────────────────────────────────
     Hide secondary nav links below ~720px to keep the header tidy.
     The Pilot CTA stays visible so the primary action remains within
     reach on mobile. */
  @media (max-width: 900px) {
    .rg-nav {
      gap: 18px;
    }
    .rg-logo .aff {
      display: none;
    }
  }
  @media (max-width: 720px) {
    .rg-header-inner {
      padding: 0 20px;
    }
    .rg-nav > a:not(.rg-header-cta) {
      display: none;
    }
  }
</style>
