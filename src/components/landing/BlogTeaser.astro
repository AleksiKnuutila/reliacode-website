---
// BlogTeaser — landing page "Latest writing" section.
//
// Renders 3 PostCards in a grid, pulled from the `posts` content
// collection. Drafts are filtered out; featured posts float to the
// front, then most-recent fills the rest.
//
// Mirrors template lines 826–866; container styles (`.b-blog`,
// `.b-blog-foot`) mirror template lines 399 and 435–440. The card
// CSS lives in PostCard.astro.

import { getCollection } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import { getPostUrl } from "@/utils/getPostPaths";
import { buildPostStamps } from "@/utils/getPostStamps";
import config from "@/config";

const allPosts = await getCollection(
  "posts",
  ({ data }) => data.draft !== true
);

// Stable "Note · NNN" stamps across the whole catalogue — same number
// on this teaser and on /posts.
const stamps = buildPostStamps(allPosts);

// Sort by date descending. Featured posts float to the front, but
// stay date-ordered among themselves so the latest featured shows
// first.
const byDateDesc = (
  a: (typeof allPosts)[number],
  b: (typeof allPosts)[number]
) => +new Date(b.data.pubDatetime) - +new Date(a.data.pubDatetime);

const featured = allPosts
  .filter(p => p.data.featured === true)
  .sort(byDateDesc);
const others = allPosts
  .filter(p => p.data.featured !== true)
  .sort(byDateDesc);
const posts = [...featured, ...others].slice(0, 3);

const locale = Astro.currentLocale ?? config.site.lang;
---

<section class="b-section" id="blog">
  <div class="b-wrap">
    <div class="b-shead">
      <div class="b-kicker">Latest writing</div>
      <h2>From the research notebook.</h2>
    </div>

    <div class="b-blog">
      {
        posts.map(p => (
          <PostCard
            href={getPostUrl(p.id, p.filePath, locale)}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDatetime}
            category={p.data.category}
            stamp={stamps.get(p.id)}
          />
        ))
      }
    </div>

    <div class="b-blog-foot">
      <span
        >Roughly one note a month. Methods, field reports, and the occasional
        position piece.</span
      >
      <a href="/posts">All notes →</a>
    </div>
  </div>
</section>

<style>
  .b-blog {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .b-blog-foot {
    margin-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    border-top: 1px dashed var(--border);
    font-size: 14px;
    color: var(--muted);
  }

  .b-blog-foot a {
    text-decoration: underline;
    text-underline-offset: 4px;
    color: var(--fg);
  }

  @media (max-width: 900px) {
    .b-blog {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .b-blog {
      grid-template-columns: 1fr;
    }
    .b-blog-foot {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
