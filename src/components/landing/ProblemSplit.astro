---
// ProblemSplit — landing page "Problem" section.
//
// Two contrasting cards driven by src/content/landing/problem.md.

import { getLandingSection } from "@/utils/getLandingSection";

const problem = await getLandingSection("problem");
---

<section class="b-section" id="problem">
  <div class="b-wrap">
    <div class="b-shead">
      <div class="b-kicker">{problem.kicker}</div>
      <h2>{problem.headline}</h2>
    </div>
    {problem.intro && <p class="b-prob-intro">{problem.intro}</p>}
    <div class="b-problem">
      {
        problem.cards.map(card => (
          <div class={`b-prob-card ${card.variant}`}>
            <div class="pn">{card.pn}</div>
            <h3>{card.h3}</h3>
            <p>{card.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .b-prob-intro {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: 40px;
  }
  .b-problem {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .b-prob-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
  }
  .b-prob-card .pn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--brand-mid);
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .b-prob-card h3 {
    font-size: 20px;
    margin: 0 0 12px;
    font-weight: 500;
  }
  .b-prob-card p {
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.7;
  }
  .b-prob-card.bad {
    border-left: 2px solid
      color-mix(in oklch, var(--brand-mid) 50%, var(--border));
  }
  .b-prob-card.good {
    border-left: 2px solid var(--brand-deep);
    background: color-mix(in oklch, var(--brand-soft) 35%, var(--card));
  }

  @media (max-width: 900px) {
    .b-problem {
      grid-template-columns: 1fr;
    }
  }
</style>
