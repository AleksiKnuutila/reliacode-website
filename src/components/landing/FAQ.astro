---
// FAQ — landing page FAQ accordion.
//
// Native <details>/<summary> driven by src/content/landing/faq.md.
// The summary's "+" rotates 45° to "×" when its parent <details> is open.

import { getLandingSection } from "@/utils/getLandingSection";

const faq = await getLandingSection("faq");
---

<section class="b-section alt" id="faq">
  <div class="b-wrap">
    <div class="b-shead">
      <div class="b-kicker">{faq.kicker}</div>
      <h2>{faq.headline}</h2>
    </div>
    <div class="b-faq">
      {
        faq.items.map(item => (
          <details open={item.open ? true : undefined}>
            <summary>
              <span class="q">{item.q}</span>
              <span class="plus">+</span>
            </summary>
            <p>{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .b-faq {
    max-width: 880px;
  }
  .b-faq details {
    border-bottom: 1px solid var(--border);
    padding: 22px 0;
  }
  .b-faq details:first-of-type {
    border-top: 1px solid var(--border);
  }
  .b-faq summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
  }
  .b-faq summary .q {
    font-size: 17px;
    font-weight: 500;
    font-family: var(--font-head);
  }
  .b-faq summary .plus {
    color: var(--brand-mid);
    font-size: 18px;
    transition: transform 0.2s;
  }
  .b-faq details[open] summary .plus {
    transform: rotate(45deg);
  }
  .b-faq details p {
    margin-top: 14px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
    max-width: 60ch;
  }
</style>
