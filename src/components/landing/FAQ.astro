---
// FAQ — landing page FAQ accordion.
//
// Section header (kicker + headline) from src/content/landing/faq.md.
// Individual Q&As are one file per question under src/content/faq/,
// sorted by the `sort` field in each file's frontmatter.

import { getCollection, render } from "astro:content";
import { getLandingSection } from "@/utils/getLandingSection";

const faq = await getLandingSection("faq");

const itemEntries = await getCollection("faq");
itemEntries.sort((a, b) => a.data.sort - b.data.sort);

// Pre-render each item's body so we can drop it into the accordion.
const items = await Promise.all(
  itemEntries.map(async entry => {
    const { Content } = await render(entry);
    return { data: entry.data, Content };
  }),
);
---

<section class="b-section alt" id="faq">
  <div class="b-wrap">
    <div class="b-shead">
      <div class="b-kicker">{faq.kicker}</div>
      <h2>{faq.headline}</h2>
    </div>
    <div class="b-faq">
      {
        items.map(({ data, Content }) => (
          <details open={data.open ? true : undefined}>
            <summary>
              <span class="q">{data.question}</span>
              <span class="plus">+</span>
            </summary>
            <div class="answer">
              <Content />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .b-faq {
    max-width: 880px;
  }
  .b-faq details {
    border-bottom: 1px solid var(--border);
    padding: 22px 0;
  }
  .b-faq details:first-of-type {
    border-top: 1px solid var(--border);
  }
  .b-faq summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
  }
  .b-faq summary .q {
    font-size: 17px;
    font-weight: 500;
    font-family: var(--font-head);
  }
  .b-faq summary .plus {
    color: var(--brand-mid);
    font-size: 18px;
    transition: transform 0.2s;
  }
  .b-faq details[open] summary .plus {
    transform: rotate(45deg);
  }
  .b-faq .answer {
    margin-top: 14px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
    max-width: 60ch;
  }
  .b-faq .answer :global(p) {
    margin: 0 0 0.8em;
  }
  .b-faq .answer :global(p:last-child) {
    margin-bottom: 0;
  }
  .b-faq .answer :global(a) {
    color: var(--brand-mid);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
