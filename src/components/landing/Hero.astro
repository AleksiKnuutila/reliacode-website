---
// Hero — landing page hero section.
//
// Composes the headline column, the verification trace mock card,
// the Truchet maze SVG that sits behind everything, and the
// "In collaboration with" partner logo rail below the main content.
//
// All copy comes from src/content/landing/main.md (frontmatter).

import { getEntry } from "astro:content";
import TruchetGrid from "./TruchetGrid.astro";
import TraceCard from "./TraceCard.astro";

const landing = await getEntry("landing", "main");
if (!landing) throw new Error("Missing src/content/landing/main.md");
const { hero } = landing.data;
---

<section class="b-hero" id="top">
  <TruchetGrid />
  <div class="b-wrap b-hero-inner">
    <div>
      <h1>
        {hero.headline_prefix}<span class="accent">{hero.headline_accent}</span>{
          hero.headline_suffix
        }
      </h1>
      <p class="lead">{hero.lead}</p>
      <div class="b-hero-cta">
        <a href={hero.cta_primary.href} class="btn-primary">
          {hero.cta_primary.label}
        </a>
        <a href={hero.cta_secondary.href} class="btn-ghost">
          {hero.cta_secondary.label}
        </a>
      </div>
    </div>
    <TraceCard />
  </div>

  {
    hero.partners.length > 0 && (
      <div class="b-collab" aria-label="In collaboration with">
        <div class="label">In collaboration with</div>
        <div class="logos">
          {hero.partners.map(p => (
            <div class="b-logo">
              {p.name}
              <span class="sub">{p.kind}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }
</section>

<style>
  .b-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--gradient-hero);
  }
  .b-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 64px;
    padding: 88px 0 80px;
    align-items: center;
  }
  .b-hero h1 {
    font-size: 68px;
    line-height: 1.04;
    letter-spacing: -0.022em;
    /* Matches template line 143: 13ch with Google-CDN Fraunces ≈ 460px
       at 68px. Pinned in px so the self-hosted variable Fraunces (with
       a wider "0" glyph at opsz=96) wraps the same way. */
    max-width: 460px;
    font-weight: 500;
  }
  .b-hero h1 .accent {
    background: linear-gradient(135deg, var(--brand-deep), var(--brand-mid));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .b-hero p.lead {
    margin-top: 28px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 48ch;
  }
  .b-hero-cta {
    margin-top: 36px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .b-hero-chips {
    margin-top: 24px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* `.b-chip` styles live in global.css so /tags, /posts/<slug>,
     and the hero all share one source. */

  /* In collaboration with — partner logo rail */
  .b-collab {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 28px 40px 56px;
    display: flex;
    align-items: center;
    gap: 36px;
    border-top: 1px dashed var(--border);
  }
  .b-collab .label {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-mid);
    max-width: 14ch;
    line-height: 1.5;
  }
  .b-collab .logos {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    flex: 1;
  }
  .b-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
    padding: 0 18px;
    border: 1px dashed var(--border-strong);
    border-radius: 6px;
    color: var(--muted);
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.01em;
    background: repeating-linear-gradient(
      135deg,
      color-mix(in oklch, var(--card) 100%, transparent) 0 14px,
      color-mix(in oklch, var(--secondary) 70%, var(--card)) 14px 15px
    );
    text-align: center;
  }
  .b-logo .sub {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand-mid);
    margin-top: 2px;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .b-hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 0 56px;
    }
    .b-hero h1 {
      font-size: 52px;
      max-width: none;
    }
    .b-hero p.lead {
      max-width: none;
    }
    .b-collab {
      flex-direction: column;
      align-items: stretch;
      gap: 18px;
      padding: 24px 24px 40px;
    }
    .b-collab .logos {
      grid-template-columns: repeat(2, 1fr);
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .b-hero h1 {
      font-size: 44px;
    }
    .b-hero-inner {
      padding: 40px 0 40px;
    }
    .b-logo {
      height: 52px;
      font-size: 14px;
      padding: 0 12px;
    }
  }
</style>
