---
// Hero — landing page hero section.
//
// Composes the headline column, the verification trace mock card, the
// Truchet maze SVG behind everything, and the "Funded by"
// partner logo rail below the main content.
//
// Editorial copy lives in src/content/landing/hero.md — flat scalars in
// frontmatter for the headline / lead / CTAs, and partners as H2 items
// in the body (`## {Name} — {Kind}`).

import { getLandingSectionWithBody } from "@/utils/getLandingSection";
import { parseSectionItems } from "@/utils/parseSectionBody";
import TruchetGrid from "./TruchetGrid.astro";

const { data: hero, body } = await getLandingSectionWithBody("hero");
const partners = parseSectionItems(body);
---

<section class="b-hero" id="top">
  <TruchetGrid />
  <div class="b-wrap b-hero-inner">
    <div>
      <h1>{hero.headline}</h1>
      {hero.lead && <p class="lead">{hero.lead}</p>}
      <div class="b-hero-cta">
        <a href={hero.cta_primary_href} class="btn-primary">
          {hero.cta_primary_label}
        </a>
        <a href={hero.cta_secondary_href} class="btn-ghost">
          {hero.cta_secondary_label}
        </a>
      </div>
    </div>
    <img
      class="b-hero-image"
      src="/frontpage.png"
      alt=""
      width="1024"
      height="521"
      loading="eager"
    />
  </div>

  {
    partners.length > 0 && (
      <div class="b-collab" aria-label="Funded by">
        <div class="label">Funded by</div>
        <div class="logos">
          {partners.map(p => (
            <div class="b-logo" title={`${p.label} — ${p.title}`}>
              {p.bodyHtml ? (
                <Fragment set:html={p.bodyHtml} />
              ) : (
                <>
                  {p.label}
                  <span class="sub">{p.title}</span>
                </>
              )}
            </div>
          ))}
        </div>
      </div>
    )
  }
</section>

<style>
  .b-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--gradient-hero);
  }
  .b-hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 64px;
    padding: 88px 0 80px;
    align-items: center;
  }
  .b-hero h1 {
    font-size: 68px;
    line-height: 1.04;
    letter-spacing: -0.022em;
    /* Matches template line 143: 13ch with Google-CDN Fraunces ≈ 460px
       at 68px. Pinned in px so the self-hosted variable Fraunces (with
       a wider "0" glyph at opsz=96) wraps the same way. */
    max-width: 460px;
    font-weight: 500;
  }
  .b-hero-image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
    border-radius: 8px;
  }
  .b-hero p.lead {
    margin-top: 28px;
    font-size: 17px;
    line-height: 1.65;
    color: var(--muted);
    max-width: 48ch;
  }
  .b-hero-cta {
    margin-top: 36px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .b-hero-chips {
    margin-top: 24px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* `.b-chip` styles live in global.css so /tags, /posts/<slug>,
     and the hero all share one source. */

  /* Funded by — partner logo rail */
  .b-collab {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 28px 40px 56px;
    display: flex;
    align-items: center;
    gap: 36px;
    border-top: 1px dashed var(--border);
  }
  .b-collab .label {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-mid);
    max-width: 14ch;
    line-height: 1.5;
  }
  .b-collab .logos {
    display: flex;
    gap: 48px;
    flex: 1;
    align-items: center;
    flex-wrap: wrap;
  }
  .b-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
  }
  .b-logo :global(img) {
    display: block;
    max-height: 56px;
    width: auto;
    max-width: 220px;
    object-fit: contain;
  }
  .b-logo :global(p) {
    margin: 0;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .b-hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 0 56px;
    }
    .b-hero h1 {
      font-size: 52px;
      max-width: none;
    }
    .b-hero p.lead {
      max-width: none;
    }
    .b-collab {
      flex-direction: column;
      align-items: stretch;
      gap: 18px;
      padding: 24px 24px 40px;
    }
    .b-collab .logos {
      gap: 32px;
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .b-hero h1 {
      font-size: 44px;
    }
    .b-hero-inner {
      padding: 40px 0 40px;
    }
    .b-logo {
      height: 56px;
    }
    .b-logo :global(img) {
      max-height: 48px;
    }
  }
</style>
