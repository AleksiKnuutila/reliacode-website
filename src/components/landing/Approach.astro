---
// Approach — landing page "Approach" section.
//
// Combines the shared shead (kicker + h2) with the three Pillars cards.
// Driven by src/content/landing/approach.md — kicker/headline as
// frontmatter scalars; pillars as H2 items in the body parsed via
// parseSectionItems.

import { getLandingSectionWithBody } from "@/utils/getLandingSection";
import { parseSectionItems } from "@/utils/parseSectionBody";

const { data: approach, body } = await getLandingSectionWithBody("approach");
const pillars = parseSectionItems(body);
---

<section class="b-section alt" id="approach">
  <div class="b-wrap">
    <div class="b-shead">
      <div class="b-kicker">{approach.kicker}</div>
      <h2>{approach.headline}</h2>
    </div>

    <div class="b-pillars">
      {
        pillars.map(pillar => (
          <div class="b-pillar">
            <div class="pn">{pillar.label}</div>
            <h3>{pillar.title}</h3>
            <div class="pillar-body" set:html={pillar.bodyHtml} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* --- Pillars --- */
  .b-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr 1.3fr;
    gap: 20px;
  }
  .b-pillar {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 320px;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .b-pillar:hover {
    border-color: var(--brand-mid);
    transform: translateY(-2px);
  }
  .b-pillar .pn {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--brand-mid);
    text-transform: uppercase;
  }
  .b-pillar h3 {
    font-size: 22px;
    line-height: 1.2;
    font-weight: 500;
  }
  .pillar-body {
    flex: 1;
  }
  .b-pillar :global(p) {
    font-size: 14.5px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* --- Responsive --- */
  @media (max-width: 900px) {
    .b-pillars {
      grid-template-columns: 1fr;
    }
    .b-pillar {
      min-height: auto;
    }
  }
</style>
