---
// CTA — landing page pilot-recruitment block.
//
// Left column: kicker + headline + lead + a single primary "Email the
// team →" button. Right column: a navy card titled "Talk to us"
// listing four tappable contact channels (email, phone, calendar,
// LinkedIn). Channels are editorial-driven from cta.md.
//
// Pilot mailbox stays in src/content/site/main.md (shared with the
// footer) so we have one canonical address.

import { getLandingSection } from "@/utils/getLandingSection";
import { getSite } from "@/utils/getSite";

const cta = await getLandingSection("cta");
const { pilot_email } = await getSite();
---

<section class="b-cta" id="contact">
  <div class="b-cta-grid" aria-hidden="true"></div>
  <div class="b-wrap b-cta-inner">
    <div>
      <div class="mono cta-kicker">{cta.kicker}</div>
      <h2>{cta.headline}</h2>
      <p>{cta.lead}</p>
      <div class="cta-actions">
        <a href={`mailto:${pilot_email}`} class="btn-light">{cta.cta_label}</a>
      </div>
    </div>
    <div class="b-cta-card">
      <h3>{cta.card_title}</h3>
      <div class="cta-channels">
        {
          cta.channels.map(ch => (
            <a
              class:list={["cta-channel", { feature: ch.feature }]}
              href={ch.href}
              target={ch.external ? "_blank" : undefined}
              rel={ch.external ? "noopener" : undefined}
            >
              <span class="ic" aria-hidden="true">
                {ch.kind === "email" && (
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="5" width="18" height="14" rx="2" />
                    <path d="M3.5 7l8.5 6 8.5-6" />
                  </svg>
                )}
                {ch.kind === "phone" && (
                  <svg viewBox="0 0 24 24">
                    <path d="M5 4h3.5l1.8 4.5-2.3 1.6a12 12 0 0 0 5.1 5.1l1.6-2.3 4.5 1.8V19a2 2 0 0 1-2 2A15.5 15.5 0 0 1 4 6a2 2 0 0 1 1-2z" />
                  </svg>
                )}
                {ch.kind === "calendar" && (
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="5" width="18" height="16" rx="2" />
                    <path d="M3 10h18M8 3v4M16 3v4" />
                  </svg>
                )}
                {ch.kind === "linkedin" && (
                  <svg viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="M7 10.5V17" />
                    <path d="M7 7.2v.01" />
                    <path d="M11.5 17v-3.6a2.1 2.1 0 0 1 4.2 0V17" />
                    <path d="M11.5 10.8V17" />
                  </svg>
                )}
              </span>
              <span class="txt">
                <span class="lbl">{ch.label}</span>
                <span class="val">{ch.value}</span>
              </span>
              {ch.external && (
                <span class="arr" aria-hidden="true">
                  ↗
                </span>
              )}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .b-cta {
    position: relative;
    overflow: hidden;
    background: var(--gradient-accent);
    color: var(--primary-fg);
  }
  .b-cta-grid {
    position: absolute;
    inset: 0;
    opacity: 0.08;
    pointer-events: none;
    background-image:
      linear-gradient(var(--primary-fg) 1px, transparent 1px),
      linear-gradient(90deg, var(--primary-fg) 1px, transparent 1px);
    background-size: 48px 48px;
    -webkit-mask-image: radial-gradient(
      ellipse at 50% 30%,
      black 40%,
      transparent 80%
    );
    mask-image: radial-gradient(
      ellipse at 50% 30%,
      black 40%,
      transparent 80%
    );
  }
  .b-cta-inner {
    position: relative;
    padding: 96px 0;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .b-cta h2 {
    color: var(--primary-fg);
    font-size: 50px;
    line-height: 1.05;
    letter-spacing: -0.018em;
    max-width: 460px;
    font-weight: 500;
  }
  .b-cta p {
    color: color-mix(in oklch, var(--primary-fg) 78%, transparent);
    font-size: 16px;
    margin-top: 22px;
    line-height: 1.65;
    max-width: 50ch;
  }
  .b-cta .btn-light {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--bg);
    color: var(--fg);
    padding: 14px 22px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
    border: 0;
    cursor: pointer;
    text-decoration: none;
  }

  .cta-kicker {
    color: color-mix(in oklch, var(--primary-fg) 75%, transparent);
    margin-bottom: 18px;
  }

  .cta-actions {
    margin-top: 32px;
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .b-cta-card {
    background: color-mix(in oklch, var(--primary-fg) 8%, transparent);
    border: 1px solid color-mix(in oklch, var(--primary-fg) 25%, transparent);
    border-radius: 10px;
    padding: 28px;
  }
  .b-cta-card h3 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--primary-fg) 80%, transparent);
    margin: 0 0 18px;
    font-weight: 500;
  }

  /* Channel rows */
  .cta-channels {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cta-channel {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 9px;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background 0.15s,
      border-color 0.15s;
  }
  .cta-channel:hover {
    background: color-mix(in oklch, var(--primary-fg) 10%, transparent);
  }
  .cta-channel .ic {
    flex: 0 0 auto;
    width: 38px;
    height: 38px;
    border-radius: 9px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in oklch, var(--primary-fg) 12%, transparent);
    border: 1px solid color-mix(in oklch, var(--primary-fg) 16%, transparent);
  }
  .cta-channel .ic svg {
    width: 17px;
    height: 17px;
    stroke: var(--primary-fg);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .cta-channel .txt {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .cta-channel .lbl {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklch, var(--primary-fg) 58%, transparent);
  }
  .cta-channel .val {
    font-size: 15px;
    font-weight: 500;
    color: color-mix(in oklch, var(--primary-fg) 94%, transparent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cta-channel .arr {
    margin-left: auto;
    padding-left: 8px;
    color: color-mix(in oklch, var(--primary-fg) 55%, transparent);
    transition:
      transform 0.15s,
      color 0.15s;
    font-size: 15px;
    line-height: 1;
  }
  .cta-channel:hover .arr {
    color: var(--primary-fg);
    transform: translate(2px, -2px);
  }
  .cta-channel.feature {
    background: color-mix(in oklch, var(--primary-fg) 9%, transparent);
    border-color: color-mix(in oklch, var(--primary-fg) 22%, transparent);
  }
  .cta-channel.feature:hover {
    background: color-mix(in oklch, var(--primary-fg) 14%, transparent);
  }

  @media (max-width: 900px) {
    .b-cta-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 64px 0;
    }
    .b-cta h2 {
      font-size: 38px;
      max-width: none;
    }
  }
  @media (max-width: 600px) {
    .b-cta h2 {
      font-size: 32px;
    }
  }
</style>
