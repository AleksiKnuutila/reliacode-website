---
// TeamGrid — landing page "Team" section.
//
// Section header (headline + intro) from src/content/landing/team.md.
// Individual members are one file per person under src/content/team/,
// each with a co-located photo (`./<slug>.{jpeg,png,jpg}`) referenced
// from the `photo:` frontmatter field. Sorted by the `sort` field.

import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { getLandingSection } from "@/utils/getLandingSection";

const team = await getLandingSection("team");

const memberEntries = await getCollection("team");
memberEntries.sort((a, b) => a.data.sort - b.data.sort);

const members = await Promise.all(
  memberEntries.map(async entry => {
    const { Content } = await render(entry);
    return { data: entry.data, Content };
  })
);
---

<section class="b-section" id="team">
  <div class="b-wrap">
    <div class="b-shead">
      <h2>{team.headline}</h2>
    </div>

    <div class="b-team-intro">
      <p>{team.intro}</p>
    </div>

    <div class="b-team">
      {
        members.map(({ data, Content }) => (
          <div class="b-tcard">
            <Image
              class="photo"
              src={data.photo}
              alt={data.name}
              widths={[160, 240, 320]}
              sizes="(max-width: 600px) 280px, (max-width: 900px) 220px, 240px"
            />
            <div class="nm">{data.name}</div>
            <div class="rl">{data.role}</div>
            <div class="bio">
              <Content />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .b-team-intro {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 64px;
    margin-bottom: 56px;
    align-items: end;
  }
  .b-team-intro p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 48ch;
  }

  .b-team {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .b-tcard {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 22px;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .b-tcard:hover {
    border-color: var(--brand-mid);
    transform: translateY(-2px);
  }
  /* Square crop so faces sit consistently regardless of source ratio. */
  .b-tcard :global(.photo) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 18px;
    background: var(--secondary);
  }
  .b-tcard .nm {
    font-family: var(--font-head);
    font-size: 17px;
    font-weight: 500;
  }
  .b-tcard .rl {
    font-size: 13px;
    color: var(--muted);
    margin-top: 4px;
    line-height: 1.5;
  }
  .b-tcard .bio {
    font-size: 13px;
    color: var(--muted);
    margin-top: 12px;
    line-height: 1.6;
  }
  .b-tcard .bio :global(p) {
    margin: 0 0 0.5em;
  }
  .b-tcard .bio :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .b-team-intro {
      grid-template-columns: 1fr;
      gap: 28px;
      margin-bottom: 40px;
    }
    .b-team {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .b-team {
      grid-template-columns: 1fr;
    }
  }
</style>
