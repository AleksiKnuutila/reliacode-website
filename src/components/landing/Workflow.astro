---
// Workflow — five-step verification loop strip.
//
// Sits inside the Approach section in index.astro, below <Pillars />.
// Renders only the `.b-workflow` block; no <section> wrapper.
//
// Mirrors template lines 666–698; styles mirror lines 309–330.
---

<div class="b-workflow">
  <div class="b-wf-head">
    <span class="ttl">Workflow · five-step loop</span>
    <span class="meta">each step writes to the run's audit bundle</span>
  </div>
  <div class="b-wf-row">
    <div class="b-wf-step">
      <span class="check">✓</span>
      <div class="sn">01</div>
      <h4>User intent</h4>
      <p>Goal &amp; stated constraints</p>
    </div>
    <div class="b-wf-step">
      <span class="check">✓</span>
      <div class="sn">02</div>
      <h4>LLM proposal</h4>
      <p>Candidate implementation</p>
    </div>
    <div class="b-wf-step">
      <span class="check">✓</span>
      <div class="sn">03</div>
      <h4>Deterministic exec.</h4>
      <p>Reproducible run</p>
    </div>
    <div class="b-wf-step">
      <span class="check">✓</span>
      <div class="sn">04</div>
      <h4>Verification</h4>
      <p>Intent &amp; constraints checked</p>
    </div>
    <div class="b-wf-step">
      <span class="check">✓</span>
      <div class="sn">05</div>
      <h4>Auditable result</h4>
      <p>Trace, inputs, outputs</p>
    </div>
  </div>
</div>

<style>
  .b-workflow {
    margin-top: 64px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 28px 32px;
  }
  .b-wf-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 22px;
  }
  .b-wf-head .ttl {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--brand-mid);
    text-transform: uppercase;
  }
  .b-wf-head .meta {
    font-size: 12px;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .b-wf-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    align-items: stretch;
  }
  .b-wf-step {
    position: relative;
    padding: 14px 18px;
    border-left: 1px solid var(--border);
  }
  .b-wf-step:first-child {
    border-left: 0;
    padding-left: 0;
  }
  .b-wf-step .sn {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--brand-mid);
    letter-spacing: 0.16em;
  }
  .b-wf-step h4 {
    margin: 6px 0 4px;
    font-size: 16px;
    font-weight: 500;
    font-family: var(--font-head);
  }
  .b-wf-step p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }
  .b-wf-step .check {
    position: absolute;
    right: 14px;
    top: 14px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--brand-mid);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-fg);
    font-size: 10px;
  }
</style>
