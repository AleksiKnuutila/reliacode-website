---
// TruchetGrid — deterministic SVG maze that fades into a clean grid.
//
// Renders the empty <svg> element plus an IIFE that builds the lines.
// The IIFE walks up to the nearest `.b-hero` ancestor via
// `svg.closest('.b-hero')`, so this component MUST be rendered inside
// the `.b-hero` element. Hero.astro handles that.
//
// The script tag below is processed by Astro's bundler (it becomes a
// deferred module script). The IIFE installs its own ResizeObserver,
// so no client directive is needed.
//
// No props — fully self-contained.
---

<svg
  class="b-hero-grid"
  id="hero-grid"
  aria-hidden="true"
  preserveAspectRatio="none"></svg>

<style>
  .b-hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
    color: var(--grid-ink);
    opacity: 0.04;
  }
</style>

<script>
  // @ts-nocheck
  /* Hero grid: a Truchet maze on the left that dissolves into a
     plain square grid on the right. The grid is constant across
     the whole canvas; per cell, a single diagonal is drawn with
     probability p(column), where p fades from 1.0 on the left to
     0.0 on the right via smoothstep. Diagonal orientation is 50/50,
     so neighboring diagonals link up across cell borders and read
     as a continuous maze. Deterministic via a small seeded RNG. */
  (function buildTruchet() {
    const svg = document.getElementById("hero-grid");
    if (!svg) return;
    const hero = svg.closest(".b-hero");
    const NS = "http://www.w3.org/2000/svg";

    const CELL = 72;
    const STROKE = 1.2;
    const FADE_START = 0.3; // left this fraction of cols: always diagonal
    const FADE_END = 0.95; // past this fraction of cols: no diagonals
    const SEED = 1337;

    // Tiny seeded RNG (mulberry32) so the maze is deterministic and
    // the same shape comes back on resize.
    function makeRng(seed) {
      let a = seed >>> 0;
      return function () {
        a = (a + 0x6d2b79f5) >>> 0;
        let t = a;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    function smoothstep(u) {
      return u * u * (3 - 2 * u);
    }

    function build() {
      const W = hero.clientWidth,
        H = hero.clientHeight;
      if (!W || !H) return;
      svg.setAttribute("viewBox", "0 0 " + W + " " + H);
      while (svg.firstChild) svg.removeChild(svg.firstChild);

      const cols = Math.ceil(W / CELL);
      const rows = Math.ceil(H / CELL);

      // Horizontal colour gradient: muted cool grey on the left
      // (where the maze lives — raw, unsettled) resolving into the
      // brand navy on the right (where the grid is clean).
      const defs = document.createElementNS(NS, "defs");
      const grad = document.createElementNS(NS, "linearGradient");
      grad.setAttribute("id", "truchet-grad");
      grad.setAttribute("gradientUnits", "userSpaceOnUse");
      grad.setAttribute("x1", 0);
      grad.setAttribute("y1", 0);
      grad.setAttribute("x2", W);
      grad.setAttribute("y2", 0);
      const stop0 = document.createElementNS(NS, "stop");
      stop0.setAttribute("offset", "0%");
      stop0.setAttribute("stop-color", "oklch(0.60 0.02 250)");
      const stop1 = document.createElementNS(NS, "stop");
      stop1.setAttribute("offset", "100%");
      stop1.setAttribute("stop-color", "oklch(0.26 0.07 255)");
      grad.appendChild(stop0);
      grad.appendChild(stop1);
      defs.appendChild(grad);
      svg.appendChild(defs);
      const STROKE_FILL = "url(#truchet-grad)";

      function addLine(x1, y1, x2, y2, cap) {
        const el = document.createElementNS(NS, "line");
        el.setAttribute("x1", x1);
        el.setAttribute("y1", y1);
        el.setAttribute("x2", x2);
        el.setAttribute("y2", y2);
        el.setAttribute("stroke", STROKE_FILL);
        el.setAttribute("stroke-width", STROKE);
        if (cap) el.setAttribute("stroke-linecap", cap);
        svg.appendChild(el);
      }

      // 1. The grid — constant across the whole hero.
      for (let c = 0; c <= cols; c++)
        addLine(c * CELL, 0, c * CELL, rows * CELL);
      for (let r = 0; r <= rows; r++)
        addLine(0, r * CELL, cols * CELL, r * CELL);

      // 2. Per-column diagonal probability.
      const p = new Array(cols);
      for (let c = 0; c < cols; c++) {
        const t = cols > 1 ? c / (cols - 1) : 0;
        if (t <= FADE_START) p[c] = 1;
        else if (t >= FADE_END) p[c] = 0;
        else {
          const u = (t - FADE_START) / (FADE_END - FADE_START);
          p[c] = 1 - smoothstep(u);
        }
      }

      // 3. Truchet diagonals, deterministic per (col, row).
      const rng = makeRng(SEED);
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const draw = rng();
          const flip = rng();
          if (draw < p[c]) {
            const x0 = c * CELL,
              y0 = r * CELL;
            const x1 = x0 + CELL,
              y1 = y0 + CELL;
            if (flip < 0.5) {
              addLine(x0, y0, x1, y1, "square"); // TL → BR
            } else {
              addLine(x1, y0, x0, y1, "square"); // TR → BL
            }
          }
        }
      }
    }

    build();
    if (typeof ResizeObserver !== "undefined") {
      new ResizeObserver(build).observe(hero);
    } else {
      window.addEventListener("resize", build);
    }
  })();
</script>
