---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { postFilter } from "@/utils/postFilter";
import { slugifyStr } from "@/utils/slugify";

// Aggregate tag counts across all visible posts. We track both the
// slug (used for the URL) and the original label (used for display)
// so the chip text matches what the author typed in frontmatter.
const posts = (await getCollection("posts")).filter(postFilter);

type TagEntry = { slug: string; label: string; count: number };
const tagMap = new Map<string, TagEntry>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    const slug = slugifyStr(t);
    const existing = tagMap.get(slug);
    if (existing) {
      existing.count += 1;
    } else {
      tagMap.set(slug, { slug, label: t, count: 1 });
    }
  }
}

const tags = [...tagMap.values()].sort((a, b) =>
  a.label.localeCompare(b.label)
);
---

<Layout
  title="Tags · ReliaParse"
  description="Notes by topic."
  currentPage="tags"
>
  <section class="b-section">
    <div class="b-wrap">
      <div class="b-shead">
        <div class="b-kicker">Tags</div>
        <h2>All notes by topic.</h2>
      </div>

      {
        tags.length === 0 ? (
          <p class="empty">No tags yet.</p>
        ) : (
          <div class="tag-cloud">
            {tags.map(({ slug, label, count }) => (
              <a class="b-chip tag-link" href={`/tags/${slug}/`}>
                <span class="tag-name">{label}</span>
                <span class="tag-count">{count}</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-link {
    text-decoration: none;
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  .tag-link:hover {
    border-color: var(--brand-mid);
    color: var(--fg);
  }

  .tag-count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--brand-mid);
    padding-left: 8px;
    border-left: 1px solid var(--border);
    margin-left: 4px;
  }

  .empty {
    color: var(--muted);
    font-size: 14px;
  }
</style>
