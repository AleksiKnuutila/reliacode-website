---
/**
 * 404 — page-not-found shell in ReliaParse voice.
 *
 * Mirrors the visual idiom of landing sections: kicker, h2, then a
 * short paragraph and two ghost-button links back into the site.
 */
import Layout from "@/layouts/Layout.astro";
import config from "@/config";
---

<Layout
  title={`Page not found | ${config.site.title}`}
  description="The page you were looking for could not be found."
>
  <section class="b-section">
    <div class="b-wrap">
      <div class="b-shead">
        <div class="b-kicker">404</div>
        <h2>Page not found.</h2>
      </div>
      <p class="not-found-body">
        This page isn't here. It may have moved, or the link may have gone stale.
      </p>
      <div class="not-found-actions">
        <a href="/" class="btn-ghost">Home →</a>
        <a href="/posts" class="btn-ghost">All notes →</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .not-found-body {
    font-size: 17px;
    color: var(--muted);
    max-width: 50ch;
    margin-bottom: 32px;
  }

  .not-found-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
