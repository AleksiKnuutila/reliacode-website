---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const allPosts = await getCollection("posts");
const sorted = getSortedPosts(allPosts);

// Group by year (descending). Maps preserve insertion order, so as
// long as we iterate `sorted` (newest → oldest) the resulting years
// come out newest → oldest too.
type Post = (typeof sorted)[number];
const groupedByYear = new Map<number, Post[]>();
for (const p of sorted) {
  const year = new Date(p.data.pubDatetime).getFullYear();
  const bucket = groupedByYear.get(year);
  if (bucket) {
    bucket.push(p);
  } else {
    groupedByYear.set(year, [p]);
  }
}

const years = [...groupedByYear.entries()].sort(([a], [b]) => b - a);

const monthDay = (d: Date | string) =>
  new Date(d)
    .toLocaleDateString("en-US", { month: "short", day: "2-digit" })
    .toUpperCase();
---

<Layout
  title="Archive · ReliaGround"
  description="All notes by year."
  currentPage="archives"
>
  <section class="b-section">
    <div class="b-wrap">
      <div class="b-shead">
        <div class="b-kicker">Archive</div>
        <h2>All notes by year.</h2>
      </div>

      {
        years.length === 0 ? (
          <p class="empty">No notes yet.</p>
        ) : (
          <div class="archive">
            {years.map(([year, posts]) => (
              <section class="year-group">
                <h3 class="year">{year}</h3>
                <ul class="year-list">
                  {posts.map(p => (
                    <li class="year-row">
                      <span class="row-date">{monthDay(p.data.pubDatetime)}</span>
                      <a
                        class="row-title"
                        href={getPostUrl(p.id, p.filePath, locale)}
                      >
                        {p.data.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .archive {
    max-width: 760px;
  }

  .year-group + .year-group {
    margin-top: 56px;
  }

  .year {
    font-family: var(--font-head);
    font-size: 36px;
    line-height: 1.1;
    font-weight: 500;
    letter-spacing: -0.018em;
    color: var(--brand-deep);
    margin-bottom: 18px;
    font-variation-settings:
      "SOFT" 50,
      "WONK" 0,
      "opsz" 96;
  }

  .year-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .year-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 14px 0;
    border-top: 1px dashed var(--border);
  }

  .year-row:last-child {
    border-bottom: 1px dashed var(--border);
  }

  .row-date {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--brand-mid);
  }

  .row-title {
    color: var(--fg);
    text-decoration: none;
    font-size: 17px;
    line-height: 1.4;
  }
  .row-title:hover {
    color: var(--brand-mid);
  }

  .empty {
    color: var(--muted);
    font-size: 14px;
  }
</style>
