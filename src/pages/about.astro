---
/**
 * /about — ReliaGround colophon page.
 *
 * Uses the shared <Layout> shell (Header + Footer + SEO) and renders the
 * `about` content entry inside the same .post-prose typography the blog
 * posts use, minus the meta strip, tags, and back link.
 */
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import config from "@/config";

const aboutEntry = await getEntry("pages", "about");
if (!aboutEntry) {
  throw new Error(
    "Missing content entry: `about.md` or `about.mdx` in `src/content/pages/`"
  );
}
const { Content } = await render(aboutEntry);
const { data } = aboutEntry;
---

<Layout
  title={`${data.title} | ${config.site.title}`}
  description={data.description}
  ogImage={data.ogImage}
  canonicalURL={data.canonicalURL}
>
  <article class="about-page">
    <header class="about-head">
      <h1 class="about-title">{data.title}</h1>
    </header>
    <div class="post-prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .about-page {
    max-width: 68ch;
    margin: 0 auto;
    padding: 80px 40px 96px;
  }

  .about-head {
    margin-bottom: 48px;
  }

  .about-title {
    font-family: var(--font-head);
    font-size: 44px;
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 500;
    font-variation-settings:
      "SOFT" 50,
      "WONK" 0,
      "opsz" 96;
    margin: 0;
  }

  @media (max-width: 620px) {
    .about-page {
      padding: 56px 24px 72px;
    }
    .about-title {
      font-size: 34px;
    }
  }
</style>
