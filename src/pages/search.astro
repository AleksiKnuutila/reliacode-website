---
import "@pagefind/default-ui/css/ui.css";
import Layout from "@/layouts/Layout.astro";
import { getAssetPath } from "@/utils/withBase";

const pagefindBundlePath = getAssetPath("pagefind/");
---

<Layout
  title="Search · ReliaGround"
  description="Search notes."
  currentPage="search"
>
  <section class="b-section">
    <div class="b-wrap">
      <div class="b-shead">
        <div class="b-kicker">Search</div>
        <h2>Find a note.</h2>
      </div>

      <div
        id="pagefind-search"
        class="pagefind-container"
        transition:persist
        data-bundle-path={pagefindBundlePath}
      >
      </div>
    </div>
  </section>
</Layout>

<script>
  function initSearch() {
    const pageFindSearch: HTMLElement | null =
      document.querySelector("#pagefind-search");

    if (!pageFindSearch) return;

    const bundlePath = pageFindSearch?.dataset?.bundlePath;
    if (!bundlePath) return;

    const params = new URLSearchParams(window.location.search);

    const onIdle = window.requestIdleCallback || (cb => setTimeout(cb, 1));

    onIdle(async () => {
      // @ts-expect-error — Missing types for @pagefind/default-ui package.
      const { PagefindUI } = await import("@pagefind/default-ui");

      // Dev-mode warning: Pagefind indexes the built site, so dev
      // mode has no index to query against until at least one build.
      if (import.meta.env.DEV) {
        pageFindSearch.innerHTML = `
            <div class="pagefind-dev-warning">
              <p><strong>DEV mode notice.</strong> Pagefind reads the built site index. Run a build at least once and use <code>npm run preview</code> to see results.</p>
            </div>
          `;
      }

      const search = new PagefindUI({
        element: "#pagefind-search",
        bundlePath,
        showImages: false,
        showSubResults: true,
        excerptLength: 25,
        translations: {
          placeholder: "Search notes…",
          zero_results: "No notes found for [SEARCH_TERM]",
        },
        processTerm: function (term: string) {
          params.set("q", term);
          history.replaceState(history.state, "", "?" + params.toString());
          return term;
        },
      });

      // If search param exists (eg: search?q=astro), trigger search
      const query = params.get("q");
      if (query) {
        search.triggerSearch(query);
      }

      // Reset search param if search input is cleared
      const searchInput = document.querySelector(".pagefind-ui__search-input");
      const clearButton = document.querySelector(".pagefind-ui__search-clear");
      searchInput?.addEventListener("input", resetSearchParam);
      clearButton?.addEventListener("click", resetSearchParam);

      function resetSearchParam(e: Event) {
        if ((e.target as HTMLInputElement)?.value.trim() === "") {
          history.replaceState(history.state, "", window.location.pathname);
        }
      }
    });
  }

  document.addEventListener("astro:after-swap", () => {
    const pagefindSearch = document.querySelector("#pagefind-search");
    if (pagefindSearch && pagefindSearch.querySelector("form")) return;
    initSearch();
  });
  initSearch();
</script>

<style is:global>
  /* Pagefind UI variable overrides — match ReliaGround tokens.
     `<style is:global>` is required because Pagefind injects its
     own markup into #pagefind-search after page load, beyond the
     reach of Astro's scoped style hash. */
  #pagefind-search.pagefind-container {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: var(--brand-mid);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--card);
    --pagefind-ui-border: var(--border);
    --pagefind-ui-tag: var(--secondary);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-body);
    --pagefind-ui-image-border-radius: 6px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    margin-top: 8px;
  }

  #pagefind-search .pagefind-ui__search-input {
    font-family: var(--font-body);
    font-size: 16px;
    background: var(--card);
    border-color: var(--border-strong);
  }
  #pagefind-search .pagefind-ui__search-input:focus,
  #pagefind-search .pagefind-ui__search-input:focus-visible {
    border-color: var(--brand-mid);
    outline: none;
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--brand-mid) 18%, transparent);
  }

  #pagefind-search .pagefind-ui__result-title a {
    font-family: var(--font-head);
    font-weight: 500;
    color: var(--fg);
    text-decoration-style: dashed;
    text-underline-offset: 4px;
  }
  #pagefind-search .pagefind-ui__result-title a:hover {
    color: var(--brand-mid);
  }
  #pagefind-search .pagefind-ui__result-title a:focus-visible {
    text-decoration-line: none;
    outline: 2px dashed var(--brand-mid);
    outline-offset: 2px;
  }

  #pagefind-search .pagefind-ui__result-excerpt mark {
    background: color-mix(in oklch, var(--brand-mid) 22%, transparent);
    color: inherit;
    padding: 0 2px;
  }

  #pagefind-search .pagefind-ui__message {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  #pagefind-search .pagefind-ui__result:last-of-type {
    border-bottom: 0;
  }

  #pagefind-search .pagefind-ui__result-nested .pagefind-ui__result-link:before {
    font-family: system-ui;
  }

  #pagefind-search .pagefind-dev-warning {
    background: color-mix(in oklch, var(--secondary) 70%, var(--card));
    border: 1px dashed var(--border-strong);
    border-radius: 6px;
    padding: 16px 18px;
    margin-bottom: 16px;
    font-size: 14px;
    color: var(--muted);
  }
  #pagefind-search .pagefind-dev-warning code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--secondary);
    padding: 0.18em 0.4em;
    border-radius: 3px;
  }
</style>
