---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/landing/Hero.astro";
import ProblemSplit from "@/components/landing/ProblemSplit.astro";
import HowItWorks from "@/components/landing/HowItWorks.astro";
import Approach from "@/components/landing/Approach.astro";
import TeamGrid from "@/components/landing/TeamGrid.astro";
import FAQ from "@/components/landing/FAQ.astro";
import BlogTeaser from "@/components/landing/BlogTeaser.astro";
import CTA from "@/components/landing/CTA.astro";

const title = "ReliaParse - From documents to defensible findings";
const description =
  "ReliaParse pairs LLMs with deterministic tools and verification methods, so analytical work stays reproducible, traceable and trustworthy.";
---

<Layout title={title} description={description} currentPage="landing">
  <Hero />
  <ProblemSplit />
  <HowItWorks />
  <Approach />
  <TeamGrid />
  <FAQ />
  <BlogTeaser />
  <CTA />
</Layout>
